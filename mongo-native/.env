########################################
# Mongo Cluster
########################################

MONGO_REPLICA_SET=rs0

########################################
# Mongo Admin
########################################

MONGO_ADMIN_USER=mongo-admin
MONGO_ADMIN_PASSWORD=Fadyadel2010!

########################################
# Shopixy Application
########################################

SHOPIXY_DB=shopixy

SHOPIXY_USER=shopixy-app
SHOPIXY_PASSWORD=Fadyadel2010!

########################################
# Storage
########################################

MONGO_STORAGE_SIZE=20Gi

########################################
# Backup
########################################

BACKUP_RETENTION_DAYS=7

########################################
# Monitoring
########################################

MONGO_EXPORTER_PORT=9216

########################################

# Remote Backup Storage

########################################

BACKUP_REMOTE=PostgressBackup
BACKUP_REMOTE_PATH=shopixy-backups/mongo
MONGO_NAMESPACE=mongo



