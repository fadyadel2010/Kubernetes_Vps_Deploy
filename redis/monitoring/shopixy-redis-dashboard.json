      },
      "datasource": {
        "type": "prometheus",
        "uid": "ffom74f70o2rkb"
      },
      "targets": [
        {
          "expr": "100 * sum(rate(redis_keyspace_hits_total{instance=~\"$instance\"}[5m])) / (sum(rate(redis_keyspace_hits_total{instance=~\"$instance\"}[5m])) + sum(rate(redis_keyspace_misses_total{instance=~\"$instance\"}[5m])))",
          "legendFormat": "Hit Ratio %",
          "refId": "A"
