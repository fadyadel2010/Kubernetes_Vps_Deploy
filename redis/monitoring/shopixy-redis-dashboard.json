                "value": null
              },
              {
                "color": "yellow",
                "value": 1000
              },
              {
                "color": "red",
                "value": 5000
              }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
