      },
      "targets": [
        {
          "expr": "sum(rate(redis_commands_duration_seconds_total{instance=~\"$instance\"}[1m])) / sum(rate(redis_commands_processed_total{instance=~\"$instance\"}[1m])) * 1e6",
          "legendFormat": "Avg Latency (us)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "\u00b5s",
          "color": {
            "mode": "thresholds"
          },
